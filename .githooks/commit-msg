#!/bin/bash
# ============================================================================
# Commit Message Hook for Java Starter Kit
# Enforces conventional commit message format
# ============================================================================

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'
BOLD='\033[1m'

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(head -n 1 "${COMMIT_MSG_FILE}" 2>/dev/null || echo "")

# Remove comments from the message
COMMIT_MSG_CLEAN=$(echo "${COMMIT_MSG}" | sed -e '/^#/d' | head -1)

# Skip merge commits, revert commits, and fixup/squash commits
if echo "${COMMIT_MSG}" | grep -qE "^(Merge|Revert|fixup!|squash!)"; then
    exit 0
fi

# Skip empty messages (shouldn't happen but just in case)
if [ -z "${COMMIT_MSG_CLEAN}" ]; then
    exit 0
fi

echo ""
echo -e "${CYAN}${BOLD}╔══════════════════════════════════════════════════════════════╗${NC}"
echo -e "${CYAN}${BOLD}║     💬  Commit Message Validation                           ║${NC}"
echo -e "${CYAN}${BOLD}╚══════════════════════════════════════════════════════════════╝${NC}"
echo ""

# Conventional commit types with descriptions
TYPES="feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert|improvement"
TYPE_DESC="Feature|Bug Fix|Documentation|Styling|Refactor|Performance|Tests|Build|CI|Chores|Revert|Improvement"

# Pattern: type(scope): description
# Pattern: type: description
CONVENTIONAL_PATTERN="^(${TYPES})(\([a-z0-9._/-]+\))?!?: .+"
JIRA_PATTERN="^[A-Z]+-[0-9]+ .+"
REVERT_PATTERN="^Revert \""

ERROR=0

if echo "${COMMIT_MSG_CLEAN}" | grep -qE "${CONVENTIONAL_PATTERN}"; then
    # Extract type and optional scope
    COMMIT_TYPE=$(echo "${COMMIT_MSG_CLEAN}" | sed -E "s/^(${TYPES}).*/\1/")
    COMMIT_SCOPE=$(echo "${COMMIT_MSG_CLEAN}" | sed -nE "s/^${TYPES}\(([a-z0-9._/-]+)\).*/\1/p")
    COMMIT_BREAKING=$(echo "${COMMIT_MSG_CLEAN}" | grep -q "!" && echo " (BREAKING CHANGE)" || echo "")

    echo -e "  ${GREEN}✓${NC} Valid conventional commit${COMMIT_BREAKING}"
    echo -e "  ${CYAN}  Type: ${NC}${COMMIT_TYPE}"
    if [ -n "${COMMIT_SCOPE}" ]; then
        echo -e "  ${CYAN}  Scope:${NC} ${COMMIT_SCOPE}"
    fi
elif echo "${COMMIT_MSG_CLEAN}" | grep -qE "${JIRA_PATTERN}"; then
    echo -e "  ${GREEN}✓${NC} Valid JIRA-style commit message"
elif echo "${COMMIT_MSG_CLEAN}" | grep -qE "${REVERT_PATTERN}"; then
    echo -e "  ${GREEN}✓${NC} Revert commit detected"
else
    echo -e "  ${RED}✗${NC} Invalid commit message format!${NC}"
    echo ""
    echo -e "  ${YELLOW}Expected format:${NC}"
    echo -e "    ${BOLD}type(scope): description${NC}"
    echo ""
    echo -e "  ${YELLOW}Types:${NC}"
    echo -e "    ${BOLD}feat${NC}      - A new feature"
    echo -e "    ${BOLD}fix${NC}       - A bug fix"
    echo -e "    ${BOLD}docs${NC}      - Documentation changes"
    echo -e "    ${BOLD}style${NC}     - Code style changes (formatting, etc.)"
    echo -e "    ${BOLD}refactor${NC}  - Code refactoring"
    echo -e "    ${BOLD}perf${NC}      - Performance improvements"
    echo -e "    ${BOLD}test${NC}      - Adding or updating tests"
    echo -e "    ${BOLD}build${NC}     - Build system changes"
    echo -e "    ${BOLD}ci${NC}        - CI configuration changes"
    echo -e "    ${BOLD}chore${NC}     - Other changes"
    echo -e "    ${BOLD}revert${NC}    - Revert previous commits"
    echo ""
    echo -e "  ${YELLOW}Examples:${NC}"
    echo -e "    ${GREEN}feat(auth): add OAuth2 login endpoint${NC}"
    echo -e "    ${GREEN}fix(cart): resolve NPE in empty cart${NC}"
    echo -e "    ${GREEN}refactor(api): extract common error handler${NC}"
    echo -e "    ${GREEN}feat!: breaking change with no scope${NC}"
    echo ""
    echo -e "  ${YELLOW}Your message:${NC} '${COMMIT_MSG_CLEAN}'"
    echo ""
    ERROR=1
fi

# Check message length (first line)
MSG_LENGTH=${#COMMIT_MSG_CLEAN}
if [ "${MSG_LENGTH}" -gt 72 ]; then
    echo -e "  ${RED}✗${NC} First line exceeds 72 characters (${MSG_LENGTH} chars)"
    ERROR=1
fi

# Check for trailing period
if echo "${COMMIT_MSG_CLEAN}" | grep -qE "\.$"; then
    echo -e "  ${YELLOW}⚠${NC} Trailing period found - consider removing it"
fi

# Check for WIP
if echo "${COMMIT_MSG_CLEAN}" | grep -qiE "^wip"; then
    echo -e "  ${YELLOW}⚠${NC} WIP commit detected - are you sure?"
fi

echo ""
if [ "${ERROR}" -eq 1 ]; then
    echo -e "  ${RED}${BOLD}Commit message rejected. Please fix and try again.${NC}"
    echo ""
    echo -e "  ${YELLOW}To bypass: git commit --no-verify -m \"your message\"${NC}"
    echo ""
    exit 1
fi

exit 0