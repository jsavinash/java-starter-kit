#!/bin/bash
# ============================================================================
# Commit Message Hook for Java Starter Kit
# Enforces conventional commit message format with enhanced validation
# ============================================================================

set -euo pipefail

# Source shared library
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/lib/shared.sh"

# Self-validate
self_validate "commit-msg"

# ============================================================================
# Get commit message
# ============================================================================
COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(head -n 1 "${COMMIT_MSG_FILE}" 2>/dev/null || echo "")

# Remove comments from the message
COMMIT_MSG_CLEAN=$(echo "${COMMIT_MSG}" | sed -e '/^#/d' | head -1)

# Skip merge commits, revert commits, and fixup/squash commits
if echo "${COMMIT_MSG}" | grep -qE "^(Merge|Revert|fixup!|squash!)"; then
    exit 0
fi

# Skip empty messages (shouldn't happen but just in case)
if [[ -z "${COMMIT_MSG_CLEAN}" ]]; then
    exit 0
fi

print_banner "💬  Commit Message Validation"

# ============================================================================
# Validation
# ============================================================================

# Conventional commit types with descriptions
TYPES="feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert|improvement"

# Pattern: type(scope): description
CONVENTIONAL_PATTERN="^(${TYPES})(\([a-z0-9._/-]+\))?!?: .+"
JIRA_PATTERN="^[A-Z]+-[0-9]+ .+"
REVERT_PATTERN="^Revert \""

ERROR=0

# --- Type/format validation ---
if echo "${COMMIT_MSG_CLEAN}" | grep -qE "${CONVENTIONAL_PATTERN}"; then
    # Extract type and optional scope
    COMMIT_TYPE=$(echo "${COMMIT_MSG_CLEAN}" | sed -E "s/^(${TYPES}).*/\1/")
    COMMIT_SCOPE=$(echo "${COMMIT_MSG_CLEAN}" | sed -nE "s/^${TYPES}\(([a-z0-9._/-]+)\).*/\1/p")
    COMMIT_BREAKING=$(echo "${COMMIT_MSG_CLEAN}" | grep -q "!" && echo " (BREAKING CHANGE)" || echo "")

    print_pass "Valid conventional commit${COMMIT_BREAKING}"
    print_detail "Type: ${COMMIT_TYPE}"
    if [[ -n "${COMMIT_SCOPE}" ]]; then
        print_detail "Scope: ${COMMIT_SCOPE}"
    fi

    # Validate scope against known project modules
    known_scopes=("auth" "cart" "order" "payment" "user" "product" "inventory" 
                  "api" "config" "notification" "offers" "review" "cache" "build"
                  "ci" "deps" "docs" "item" "recommendation" "serviceability"
                  "api-gateway" "config-server" "service-discovery"
                  "archival" "item-management" "review-and-ratings")
    is_valid_scope=false
    if [[ -n "${COMMIT_SCOPE}" ]]; then
        for scope in "${known_scopes[@]}"; do
            if [[ "${COMMIT_SCOPE}" == "${scope}" ]]; then
                is_valid_scope=true
                break
            fi
        done
        if [[ "${is_valid_scope}" == "false" ]]; then
            print_warn "Unknown scope '${COMMIT_SCOPE}' - not in known scopes"
            print_detail "Known scopes: ${known_scopes[*]}"
        fi
    fi

elif echo "${COMMIT_MSG_CLEAN}" | grep -qE "${JIRA_PATTERN}"; then
    print_pass "Valid JIRA-style commit message"
elif echo "${COMMIT_MSG_CLEAN}" | grep -qE "${REVERT_PATTERN}"; then
    print_pass "Revert commit detected"
else
    print_fail "Invalid commit message format!"
    echo ""
    print_info "Expected format: type(scope): description"
    echo ""
    print_info "Types: feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert"
    echo ""
    print_info "Examples:"
    print_detail "  feat(auth): add OAuth2 login endpoint"
    print_detail "  fix(cart): resolve NPE in empty cart"
    print_detail "  refactor(api): extract common error handler"
    print_detail "  feat!: breaking change with no scope"
    echo ""
    print_info "Your message: '${COMMIT_MSG_CLEAN}'"
    ERROR=1
fi

# --- Message length check ---
MSG_LENGTH=${#COMMIT_MSG_CLEAN}
if [[ "${MSG_LENGTH}" -gt 72 ]]; then
    print_fail "First line exceeds 72 characters (${MSG_LENGTH} chars)"
    ERROR=1
else
    print_pass "First line is ${MSG_LENGTH} chars (limit 72)"
fi

# --- Subject should not end with period ---
if echo "${COMMIT_MSG_CLEAN}" | grep -qE "\.$"; then
    print_warn "Trailing period found in subject - consider removing it"
fi

# --- Subject should be capitalized ---
if echo "${COMMIT_MSG_CLEAN}" | grep -qE "^[a-z][a-zA-Z]*\(.*\): [a-z]"; then
    print_warn "Description should start with a capital letter"
fi

# --- WIP check ---
if echo "${COMMIT_MSG_CLEAN}" | grep -qiE "^wip"; then
    print_warn "WIP commit detected - are you sure?"
fi

# --- Check for body if commit is complex ---
if [[ "${COMMIT_MSG_CLEAN}" != "${COMMIT_MSG}" ]]; then
    # There's a body
    body_lines=$(echo "${COMMIT_MSG}" | grep -v "^#" | tail -n +2 | sed '/^$/d' | wc -l | tr -d ' ')
    if [[ "${body_lines}" -gt 0 ]]; then
        print_detail "Commit body has ${body_lines} line(s)"
        
        # Check body line length
        long_body_lines=0
        while IFS= read -r line; do
            line_length=${#line}
            if [[ "${line_length}" -gt 72 ]]; then
                long_body_lines=$((long_body_lines + 1))
            fi
        done <<< "$(echo "${COMMIT_MSG}" | grep -v "^#" | tail -n +2)"
        
        if [[ "${long_body_lines}" -gt 0 ]]; then
            print_warn "${long_body_lines} body line(s) exceed 72 characters"
        fi
    fi
fi

# ============================================================================
# Summary
# ============================================================================
echo ""
if [[ "${ERROR}" -eq 1 ]]; then
    echo -e "  ${RED}${BOLD}Commit message rejected. Please fix and try again.${NC}"
    echo ""
    echo -e "  ${YELLOW}To bypass: git commit --no-verify -m \"your message\"${NC}"
    echo ""
    exit 1
fi

print_pass "Commit message validated successfully"
exit 0