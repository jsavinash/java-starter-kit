#!/bin/bash
# ============================================================================
# Pre-push Hook for Java Starter Kit
# Deep & robust push-time checks with full CI simulation, commit history
# validation, and dependency verification.
# ============================================================================

set -euo pipefail

# Source shared library
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/lib/shared.sh"

# Self-validate
self_validate "pre-push"

# ============================================================================
# Start
# ============================================================================
HOOK_START=$(date +%s)

# Get remote info from arguments
REMOTE="${1:-origin}"
REMOTE_URL="${2:-}"
CURRENT_BRANCH="${CURRENT_BRANCH:-$(git symbolic-ref HEAD 2>/dev/null | sed 's|refs/heads/||')}"

print_banner "📤  Pre-Push Quality Checks" "${CYAN}"

# ============================================================================
# Check 0: Dependency Verification (full check)
# ============================================================================
print_section "0" "6" "🔧" "Dependency Check"

check_all_dependencies "full"

# ============================================================================
# Check 1: Protected branch push protection
# ============================================================================
print_section "1" "6" "🔒" "Branch Push Protection"

PROTECTED_BRANCHES="^(main|master|develop)$"
push_blocked=false

# Read stdin to get the refs being pushed
while read local_ref local_sha remote_ref remote_sha; do
    TARGET_BRANCH=$(echo "${remote_ref}" | sed 's|refs/heads/||')
    
    if echo "${TARGET_BRANCH}" | grep -qE "${PROTECTED_BRANCHES}"; then
        # Check if this is initial setup
        COMMIT_COUNT=$(git rev-list --count HEAD 2>/dev/null || echo "0")
        if [[ "${COMMIT_COUNT}" -lt 3 ]]; then
            print_info "Initial setup push to '${TARGET_BRANCH}' - allowing"
            print_pass "Push to '${TARGET_BRANCH}' is allowed (initial setup)"
        else
            print_fail "Direct pushes to '${TARGET_BRANCH}' are NOT allowed!"
            print_info "Please create a Pull Request instead"
            push_blocked=true
        fi
    else
        print_pass "Push to '${TARGET_BRANCH}' is allowed"
    fi
done

if [[ "${push_blocked}" == "true" ]]; then
    echo ""
    print_fail "Protected branch push blocked"
    print_info "Create a feature branch and use PRs to merge into protected branches"
fi

# ============================================================================
# Check 2: Full test suite
# ============================================================================
print_section "2" "6" "🧪" "Full Test Suite"

TESTS_START=$(date +%s)

if command -v ./gradlew &>/dev/null && [[ -x ./gradlew ]]; then
    print_info "Running full test suite across all modules..."
    test_report="${REPORT_DIR}/push-tests-${TIMESTAMP}.log"

    if ./gradlew --no-daemon --build-cache test > "${test_report}" 2>&1; then
        print_pass "All tests passed"
    else
        test_failures=$(grep -c "FAILED\|failures" "${test_report}" 2>/dev/null || echo "0")
        print_fail "Tests failed (${test_failures} failures)"
        grep -A3 "FAILED\|tests failed" "${test_report}" 2>/dev/null | head -20
        echo -e "  ${RED}   See: ${test_report}${NC}"
        print_info "Run './gradlew test' locally for details"
    fi
else
    print_warn "Gradle wrapper not found - skipping tests"
fi

TESTS_ELAPSED=$(( $(date +%s) - TESTS_START ))
print_timing "${TESTS_ELAPSED}" "Tests"

# ============================================================================
# Check 3: Full code quality
# ============================================================================
print_section "3" "6" "📊" "Full Code Quality Check"

QUALITY_START=$(date +%s)

if command -v ./gradlew &>/dev/null && [[ -x ./gradlew ]]; then
    # Run quality checks in parallel
    quality_tasks=(
        "Checkstyle (Java)" "./gradlew checkstyleMain checkstyleTest --no-daemon --build-cache --parallel"
        "Detekt (Kotlin)" "./gradlew detektMain detektTest --no-daemon --build-cache --parallel"
        "PMD (Java)" "./gradlew pmdMain pmdTest --no-daemon --build-cache --parallel"
        "Spotless (Formatting)" "./gradlew spotlessCheck --no-daemon --build-cache --parallel"
    )

    run_parallel "quality checks" "${quality_tasks[@]}" || true
else
    print_warn "Gradle wrapper not found - skipping quality checks"
fi

QUALITY_ELAPSED=$(( $(date +%s) - QUALITY_START ))
print_timing "${QUALITY_ELAPSED}" "Quality checks"

# ============================================================================
# Check 4: Commit history inspection
# ============================================================================
print_section "4" "6" "📜" "Commit History Check"

history_issues=0

while read local_ref local_sha remote_ref remote_sha; do
    if [[ "${local_ref}" = "(delete)" ]]; then
        continue
    fi
    
    RANGE="${remote_sha}..${local_sha}"
    
    # Check for merge commits in feature branches
    merge_commits=$(git rev-list --merges "${RANGE}" 2>/dev/null | wc -l | tr -d ' ')
    if [[ "${merge_commits}" -gt 0 ]]; then
        print_warn "${merge_commits} merge commit(s) found in push"
        print_info "Consider rebasing instead of merging for cleaner history"
        history_issues=$((history_issues + 1))
    fi
    
    # Check for large commits (>200 files changed)
    large_commits=0
    for commit in $(git rev-list "${RANGE}" 2>/dev/null); do
        files_changed=$(git diff-tree --no-commit-id --name-only -r "${commit}" 2>/dev/null | wc -l | tr -d ' ')
        if [[ "${files_changed}" -gt 200 ]]; then
            print_warn "Commit ${commit:0:8} changes ${files_changed} files - consider splitting"
            large_commits=$((large_commits + 1))
            history_issues=$((history_issues + 1))
        fi
    done

    if [[ "${large_commits}" -gt 0 ]]; then
        print_warn "${large_commits} overly large commit(s) detected"
    fi
    
    # Check commit messages follow convention
    non_conv_commits=0
    conv_pattern="^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert|improvement)(\([a-z0-9._/-]+\))?!?: .+"
    for commit in $(git rev-list "${RANGE}" 2>/dev/null); do
        commit_msg=$(git log --format=%s -1 "${commit}" 2>/dev/null || echo "")
        
        # Skip merge/revert commits
        if echo "${commit_msg}" | grep -qE "^(Merge|Revert)"; then
            continue
        fi
        
        if ! echo "${commit_msg}" | grep -qE "${conv_pattern}"; then
            non_conv_commits=$((non_conv_commits + 1))
            if [[ "${non_conv_commits}" -le 3 ]]; then
                print_warn "Non-conventional commit: ${commit:0:8} - '${commit_msg}'"
            fi
        fi
    done
    
    if [[ "${non_conv_commits}" -eq 0 ]]; then
        print_pass "All commit messages follow conventional commits format"
    else
        print_warn "${non_conv_commits} commit(s) don't follow conventional format"
        print_info "Learn more: https://www.conventionalcommits.org/"
    fi
done

if [[ "${history_issues}" -eq 0 ]]; then
    print_pass "Commit history looks good"
fi

# ============================================================================
# Check 5: Unpushed commit validation
# ============================================================================
print_section "5" "6" "🔄" "Unpushed Work Validation"

unpushed_count=$(git log --oneline "@{upstream}..HEAD" 2>/dev/null | wc -l | tr -d ' ' || echo "0")

if [[ "${unpushed_count}" -gt 0 ]]; then
    print_info "${unpushed_count} unpushed commit(s) detected"
    
    # Check for fixup/squash commits
    fixup_count=$(git log --oneline "@{upstream}..HEAD" 2>/dev/null | grep -c "fixup!\|squash!" || echo "0")
    if [[ "${fixup_count}" -gt 0 ]]; then
        print_fail "${fixup_count} fixup!/squash! commit(s) found - run 'git rebase -i' to squash them"
    fi
    
    # Check for WIP commits
    wip_count=$(git log --oneline "@{upstream}..HEAD" 2>/dev/null | grep -ci "wip\|WIP" || echo "0")
    if [[ "${wip_count}" -gt 0 ]]; then
        print_warn "${wip_count} WIP commit(s) found - are you sure they're ready?"
    fi
else
    print_pass "No new commits to push"
fi

# ============================================================================
# Check 6: Dependency vulnerability scan (CI delegates)
# ============================================================================
print_section "6" "6" "🔒" "Dependency Vulnerability Check"

if command -v ./gradlew &>/dev/null; then
    print_info "OWASP Dependency Check delegated to CI pipeline"
    print_info "For local scan: ./gradlew dependencyCheckAnalyze"
    print_pass "Dependency vulnerability check runs in CI"
fi

# ============================================================================
# Summary
# ============================================================================
HOOK_ELAPSED=$(( $(date +%s) - HOOK_START ))
show_summary "PUSH" "${HOOK_ELAPSED}"