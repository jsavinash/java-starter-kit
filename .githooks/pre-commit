#!/bin/bash
# ============================================================================
# Pre-commit Hook for Java Starter Kit
# Deep & robust quality checks with dependency verification, smart scoping,
# parallel execution, secret scanning, and progressive validation.
# ============================================================================

set -euo pipefail

# Source shared library
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/lib/shared.sh"

# Self-validate
self_validate "pre-commit"

# ============================================================================
# Start
# ============================================================================
HOOK_START=$(date +%s)
init_hook

print_banner "🚀  Java Starter Kit - Pre-Commit Quality Checks"

# ============================================================================
# Check 0: Dependency Verification
# ============================================================================
print_section "0" "9" "🔧" "Dependency Check"

check_all_dependencies "quick"

# ============================================================================
# Check 1: Branch Protection
# ============================================================================
print_section "1" "9" "🔒" "Branch Protection Check"

PROTECTED_BRANCHES="^(main|master|develop)$"

if echo "${CURRENT_BRANCH}" | grep -qE "${PROTECTED_BRANCHES}"; then
    COMMIT_COUNT=$(git rev-list --count HEAD 2>/dev/null || echo "0")
    if [[ "${COMMIT_COUNT}" -eq 0 ]]; then
        print_info "Initial commit to '${CURRENT_BRANCH}' - allowing for setup"
        print_pass "Branch '${CURRENT_BRANCH}' is valid for initial commit"
    else
        print_warn "Direct commits to '${CURRENT_BRANCH}' should use a feature branch and PR."
        print_pass "Branch '${CURRENT_BRANCH}' check passed (warning only)"
    fi
else
    print_pass "Branch '${CURRENT_BRANCH}' is valid for commits"
fi

# ============================================================================
# Check 2: Staged Files Validation (enhanced)
# ============================================================================
print_section "2" "9" "📝" "Staged Files Validation"

STAGED_COUNT=$(get_staged_count)
if [[ "${STAGED_COUNT}" -eq 0 ]]; then
    print_info "No staged files to validate"
    print_info "Use 'git add <files>' to stage changes before committing"
else
    print_pass "${STAGED_COUNT} file(s) staged"

    # Smart scope detection - what type of checks to run
    if has_java_files; then
        print_info "Java files detected - will run Java-specific checks"
    fi
    if has_kotlin_files; then
        print_info "Kotlin files detected - will run Kotlin-specific checks"
    fi
    if has_gradle_files; then
        print_info "Gradle files detected - will run build-specific checks"
    fi

    # --- Merge conflict markers ---
    if echo "${STAGED_FILES}" | xargs grep -l "^<<<<<<< \|^=======$\|^>>>>>>> " 2>/dev/null; then
        print_fail "Merge conflict markers found in staged files!"
    else
        print_pass "No merge conflict markers"
    fi

    # --- Large file detection ---
    large_files=()
    while IFS= read -r file; do
        if [[ -f "${file}" ]]; then
            size=$(stat -f%z "${file}" 2>/dev/null || stat -c%s "${file}" 2>/dev/null || echo "0")
            if [[ "${size:-0}" -gt 1048576 ]]; then
                large_files+=("${file}")
            fi
        fi
    done <<< "${STAGED_FILES}"

    if [[ ${#large_files[@]} -gt 0 ]]; then
        print_fail "Large files detected (>1MB):"
        for lf in "${large_files[@]}"; do
            echo -e "  ${RED}   - ${lf}${NC}"
        done
    else
        print_pass "No large files detected"
    fi

    # --- Forbidden files ---
    forbidden_extensions="\.(class|jar|war|ear|zip|tar\.gz|7z|dll|exe|so|dylib|keystore|jks|p12|pfx|deb|rpm)$"
    forbidden_files=()
    while IFS= read -r file; do
        if echo "${file}" | grep -qiE "${forbidden_extensions}"; then
            forbidden_files+=("${file}")
        fi
    done <<< "${STAGED_FILES}"

    if [[ ${#forbidden_files[@]} -gt 0 ]]; then
        print_fail "Binary/forbidden files staged:"
        for ff in "${forbidden_files[@]}"; do
            echo -e "  ${RED}   - ${ff}${NC}"
        done
    else
        print_pass "No forbidden file types"
    fi

    # --- Whitespace/EOF check ---
    whitespace_issues=()
    while IFS= read -r file; do
        if [[ -f "${file}" ]] && file "${file}" | grep -qi "text"; then
            # Check for trailing whitespace
            if grep -l "[[:space:]]$" "${file}" &>/dev/null; then
                whitespace_issues+=("${file} (trailing whitespace)")
            fi
            # Check for missing trailing newline
            if [[ -s "${file}" ]] && [[ "$(tail -c 1 "${file}" | wc -l)" -eq 0 ]]; then
                whitespace_issues+=("${file} (no newline at EOF)")
            fi
        fi
    done <<< "${STAGED_FILES}"

    if [[ ${#whitespace_issues[@]} -gt 0 ]]; then
        print_fail "Whitespace issues found:"
        for wi in "${whitespace_issues[@]}"; do
            echo -e "  ${RED}   - ${wi}${NC}"
        done
    else
        print_pass "No whitespace issues"
    fi

    # --- Secret scanning ---
    secret_files=$(scan_for_secrets "${STAGED_FILES}" 2>/dev/null || true)
    if [[ -n "${secret_files}" ]]; then
        print_fail "Potential secrets detected in files:"
        echo -e "  ${RED}${secret_files}${NC}"
        print_info "Remove secrets before committing or use .gitignore"
    else
        print_pass "No secrets detected"
    fi

    # --- TODO/FIXME scan (informational) ---
    todo_count=$(scan_for_todos "${STAGED_FILES}")
    if [[ "${todo_count}" -gt 0 ]]; then
        print_warn "${todo_count} TODO/FIXME/HACK markers found in staged files"
    fi
fi

# ============================================================================
# Check 3: Commit Message Validation
# ============================================================================
print_section "3" "9" "💬" "Commit Message Validation"

COMMIT_MSG_FILE=$(get_commit_msg_file "${1:-}")
COMMIT_MSG=$(get_commit_message "${COMMIT_MSG_FILE}")

if [[ -n "${COMMIT_MSG}" ]]; then
    # Conventional commit pattern
    conv_pattern="^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert|improvement)(\([a-z0-9._/-]+\))?!?: .+"
    jira_pattern="^[A-Z]+-[0-9]+ .+"

    if echo "${COMMIT_MSG}" | grep -qE "${conv_pattern}"; then
        print_pass "Commit message follows conventional commits format"
    elif echo "${COMMIT_MSG}" | grep -qE "${jira_pattern}"; then
        print_pass "Commit message follows JIRA ticket format"
    elif echo "${COMMIT_MSG}" | grep -qE "^Revert \""; then
        print_pass "Revert commit detected"
    else
        print_fail "Commit message does not follow conventional commits format!"
        print_info "Format: type(scope): description"
        print_info "Types: feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert"
        print_info "Example: feat(auth): add login endpoint"
    fi

    # Check message length
    msg_length=${#COMMIT_MSG}
    if [[ "${msg_length}" -gt 72 ]]; then
        print_fail "First line exceeds 72 characters (${msg_length} chars)"
    else
        print_pass "First line is ${msg_length} chars (limit 72)"
    fi

    # Check for WIP
    if echo "${COMMIT_MSG}" | grep -qiE "^wip"; then
        print_warn "WIP commit detected - are you sure you want to commit?"
    fi
else
    print_fail "Commit message is empty!"
fi

# ============================================================================
# Check 4: Secret & Credential Scan (deep scan)
# ============================================================================
print_section "4" "9" "🕵️" "Deep Secret & Credential Scan"

# Scan all staged content (not just filenames) for secrets
secrets_found=0
secret_scan_report="${REPORT_DIR}/secrets-${TIMESTAMP}.log"

# Use git diff to scan actual content changes
git diff --cached -U0 2>/dev/null | grep -E "^\+" | grep -viE "^\+\+\+" | grep -viE "^\+$" > "${CACHE_DIR}/staged-diff-${TIMESTAMP}" 2>/dev/null || true

# High-confidence patterns that must never appear in code
high_confidence_patterns=(
    'AKIA[0-9A-Z]{16}'           # AWS Access Key ID
    '-----BEGIN (RSA |EC )?PRIVATE KEY-----'
    'ghp_[A-Za-z0-9]{36}'        # GitHub PAT
    'gho_[A-Za-z0-9]{36}'        # GitHub OAuth
    'github_pat_[A-Za-z0-9_]{82}'
    'sk-[A-Za-z0-9]{32,}'        # OpenAI
    'xox[baprs]-[A-Za-z0-9-]{24,}' # Slack
    'pk_live_[A-Za-z0-9]{24,}'   # Stripe live
    'sk_live_[A-Za-z0-9]{24,}'   # Stripe live secret
)

for pattern in "${high_confidence_patterns[@]}"; do
    if grep -qE "${pattern}" "${CACHE_DIR}/staged-diff-${TIMESTAMP}" 2>/dev/null; then
        print_fail "High-confidence secret pattern detected!"
        print_info "Pattern: ${pattern}"
        print_info "Check the diff and remove any hardcoded credentials"
        secrets_found=$((secrets_found + 1))
    fi
done

if [[ "${secrets_found}" -eq 0 ]]; then
    print_pass "No credentials/secrets detected in staged changes"
fi

rm -f "${CACHE_DIR}/staged-diff-${TIMESTAMP}" 2>/dev/null || true

# ============================================================================
# Check 5: Code Formatting (Spotless) - Smart scoping
# ============================================================================
print_section "5" "9" "🎨" "Code Formatting Check"

FORMATTING_START=$(date +%s)

if has_java_files || has_kotlin_files || has_gradle_files; then
    if command -v ./gradlew &>/dev/null; then
        spotless_cache_key=$(cache_key_from_files "spotless" "${STAGED_FILES}")
        spotless_cached=$(cache_get "${spotless_cache_key}" 2>/dev/null || echo "")

        if [[ -n "${spotless_cached}" ]]; then
            print_pass "Spotless check (cached from previous run)"
        else
            print_info "Running: spotlessCheck (focused on changed modules)..."
            spotless_report="${REPORT_DIR}/spotless-${TIMESTAMP}.log"

            # Determine which modules need checking based on staged files
            modules_to_check=""
            while IFS= read -r file; do
                module_path=$(echo "${file}" | grep -oE "apps/micro-services/[^/]+" | head -1 || true)
                if [[ -n "${module_path}" ]]; then
                    modules_to_check+=":${module_path}:spotlessCheck "
                fi
            done <<< "${STAGED_FILES}"

            if [[ -n "${modules_to_check}" ]]; then
                # Only check affected modules
                if eval "./gradlew --no-daemon --build-cache --parallel ${modules_to_check}" > "${spotless_report}" 2>&1; then
                    print_pass "Spotless formatting passed"
                    cache_set "${spotless_cache_key}" "passed"
                else
                    print_fail "Spotless formatting failed!"
                    grep -A2 "FAILURE\|ERROR\|BUILD FAILED" "${spotless_report}" 2>/dev/null | head -20
                    print_info "Run './gradlew spotlessApply' to auto-fix formatting"
                    echo -e "  ${RED}   See: ${spotless_report}${NC}"
                fi
            else
                # Run top-level check as fallback
                if ./gradlew spotlessCheck --no-daemon --build-cache --parallel > "${spotless_report}" 2>&1; then
                    print_pass "Spotless formatting passed"
                    cache_set "${spotless_cache_key}" "passed"
                else
                    print_fail "Spotless formatting failed!"
                    grep -A2 "FAILURE\|ERROR\|BUILD FAILED" "${spotless_report}" 2>/dev/null | head -20
                    print_info "Run './gradlew spotlessApply' to auto-fix formatting"
                    echo -e "  ${RED}   See: ${spotless_report}${NC}"
                fi
            fi
        fi
    else
        print_warn "Gradle wrapper not found - skipping formatting check"
    fi
else
    print_pass "No Java/Kotlin/Gradle files changed - skipping formatting check (smart scoping)"
fi

FORMATTING_ELAPSED=$(( $(date +%s) - FORMATTING_START ))
print_timing "${FORMATTING_ELAPSED}" "Formatting"

# ============================================================================
# Check 6: Static Code Analysis - Checkstyle (Java)
# ============================================================================
print_section "6" "9" "📐" "Checkstyle Analysis (Java)"

if has_java_files; then
    if command -v ./gradlew &>/dev/null; then
        print_info "Running: checkstyleMain for changed modules..."
        checkstyle_report="${REPORT_DIR}/checkstyle-${TIMESTAMP}.log"

        if ./gradlew checkstyleMain --no-daemon --build-cache --parallel > "${checkstyle_report}" 2>&1; then
            print_pass "Checkstyle Java analysis passed"
        else
            cs_errors=$(grep -c "ERROR\|FAILURE\|BUILD FAILED" "${checkstyle_report}" 2>/dev/null || echo "0")
            print_fail "Checkstyle found ${cs_errors} issue(s)"
            grep -B1 -A2 "ERROR" "${checkstyle_report}" 2>/dev/null | head -30
            echo -e "  ${RED}   See: ${checkstyle_report}${NC}"
        fi
    fi
else
    print_pass "No Java files changed - skipping Checkstyle (smart scoping)"
fi

# ============================================================================
# Check 7: Static Code Analysis - Detekt (Kotlin) + PMD
# ============================================================================
print_section "7" "9" "🔍" "Static Code Analysis (Kotlin + Java)"

# Run Detekt and PMD in parallel if applicable
parallel_tasks=()

if has_kotlin_files && command -v ./gradlew &>/dev/null; then
    parallel_tasks+=("Detekt (Kotlin)" "./gradlew detektMain --no-daemon --build-cache --parallel")
fi

if has_java_files && command -v ./gradlew &>/dev/null; then
    parallel_tasks+=("PMD (Java)" "./gradlew pmdMain --no-daemon --build-cache --parallel")
fi

if [[ ${#parallel_tasks[@]} -gt 0 ]]; then
    run_parallel "static analysis" "${parallel_tasks[@]}"
elif has_java_files || has_kotlin_files; then
    print_pass "No relevant analysis tools configured for changed files"
else
    print_pass "No Java/Kotlin files changed - skipping static analysis (smart scoping)"
fi

# ============================================================================
# Check 8: Unit Tests & Coverage (focused)
# ============================================================================
print_section "8" "9" "🧪" "Unit Tests & Coverage"

TESTS_START=$(date +%s)

if command -v ./gradlew &>/dev/null; then
    # Smart test selection: only test modules with source changes
    test_modules=""
    while IFS= read -r file; do
        module_name=$(echo "${file}" | grep -oE "^apps/micro-services/[^/]+" | head -1 || true)
        if [[ -n "${module_name}" ]] && [[ ! "${test_modules}" =~ ${module_name} ]]; then
            test_modules+=" ${module_name}"
        fi
    done <<< "${STAGED_FILES}"

    if [[ -n "${test_modules}" ]]; then
        # Build module test tasks
        test_tasks=""
        for mod in ${test_modules}; do
            test_tasks+=":${mod//\//:}:test "
        done

        print_info "Running tests for affected modules..."
        test_report="${REPORT_DIR}/test-${TIMESTAMP}.log"

        if eval "./gradlew --no-daemon --build-cache --parallel ${test_tasks}" > "${test_report}" 2>&1; then
            print_pass "Unit tests passed for affected modules"
        else
            test_failures=$(grep -c "FAILED\|failures" "${test_report}" 2>/dev/null || echo "0")
            print_fail "Unit tests failed (${test_failures} failures)"
            grep -A3 "FAILED\|tests failed" "${test_report}" 2>/dev/null | head -20
            echo -e "  ${RED}   See: ${test_report}${NC}"
        fi
    else
        # Quick smoke test - compile only
        print_info "No source module changes detected - running compile check..."
        if ./gradlew compileJava compileTestJava --no-daemon --build-cache --parallel > "${REPORT_DIR}/compile-${TIMESTAMP}.log" 2>&1; then
            print_pass "Compilation check passed"
        else
            print_fail "Compilation failed!"
            grep -A2 "ERROR\|BUILD FAILED" "${REPORT_DIR}/compile-${TIMESTAMP}.log" 2>/dev/null | head -10
        fi
    fi
else
    print_warn "Gradle wrapper not found - skipping tests"
fi

TESTS_ELAPSED=$(( $(date +%s) - TESTS_START ))
print_timing "${TESTS_ELAPSED}" "Tests"

# ============================================================================
# Check 9: Dependency Vulnerability (quick check)
# ============================================================================
print_section "9" "9" "🔒" "Dependency Vulnerability Check"

if command -v ./gradlew &>/dev/null; then
    if has_gradle_files; then
        print_info "Gradle files changed - dependency configurations may have changed"
    fi
    print_pass "Dependency vulnerability check runs in CI pipeline"
    print_info "For local check: ./gradlew dependencyCheckAnalyze"
fi

# ============================================================================
# Summary
# ============================================================================
HOOK_ELAPSED=$(( $(date +%s) - HOOK_START ))
show_summary "COMMIT" "${HOOK_ELAPSED}"