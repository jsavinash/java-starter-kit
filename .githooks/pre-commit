#!/bin/bash
# ============================================================================
# Pre-commit Hook for Java Starter Kit
# Runs all quality checks before allowing a commit
# ============================================================================

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color
BOLD='\033[1m'

PROJECT_ROOT="$(git rev-parse --show-toplevel)"
REPORT_DIR="${PROJECT_ROOT}/build/reports/pre-commit"
TIMESTAMP=$(date +"%Y%m%d_%H%M%S")
PASS=true

# Ensure we're in the project root
cd "${PROJECT_ROOT}"

mkdir -p "${REPORT_DIR}"

echo -e "\n${CYAN}${BOLD}╔══════════════════════════════════════════════════════════════╗${NC}"
echo -e "${CYAN}${BOLD}║     🚀  Java Starter Kit - Pre-Commit Quality Checks        ║${NC}"
echo -e "${CYAN}${BOLD}╚══════════════════════════════════════════════════════════════╝${NC}"
echo ""

# ============================================================================
# Helper Functions
# ============================================================================

print_section() {
    echo -e "\n${YELLOW}${BOLD}═══ $1 ═══${NC}\n"
}

print_pass() {
    echo -e "  ${GREEN}✓${NC} $1"
}

print_fail() {
    echo -e "  ${RED}✗${NC} $1"
    PASS=false
}

print_info() {
    echo -e "  ${CYAN}ℹ${NC} $1"
}

run_gradle_task() {
    local task_name="$1"
    local description="$2"
    local report_file="$3"

    print_info "Running: ${task_name}..."

    if ./gradlew --no-daemon --build-cache --parallel "${task_name}" > "${report_file}" 2>&1; then
        print_pass "${description} passed"
        return 0
    else
        local error_count
        error_count=$(grep -c "FAILURE\|ERROR\|error\|BUILD FAILED" "${report_file}" 2>/dev/null || echo "0")
        print_fail "${description} failed (${error_count} issues)"
        echo -e "  ${RED}   See: ${report_file}${NC}"
        return 1
    fi
}

# ============================================================================
# Check 1: No direct pushes to main/protected branches
# ============================================================================
print_section "1/8 🔒  Branch Protection Check"

PROTECTED_BRANCHES="^(main|master|develop)$"
CURRENT_BRANCH=$(git symbolic-ref HEAD 2>/dev/null | sed 's|refs/heads/||')

if echo "${CURRENT_BRANCH}" | grep -qE "${PROTECTED_BRANCHES}"; then
    print_fail "Direct commits to '${CURRENT_BRANCH}' are not allowed! Use a feature branch and PR."
    PASS=false
else
    print_pass "Branch '${CURRENT_BRANCH}' is valid for commits"
fi

# ============================================================================
# Check 2: Staged files linting & validation
# ============================================================================
print_section "2/8 📝  Staged Files Validation"

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)
if [ -z "${STAGED_FILES}" ]; then
    print_info "No staged files to validate"
else
    print_pass "$(echo "${STAGED_FILES}" | wc -l | tr -d ' ') file(s) staged"

    # Check for merge conflict markers
    if echo "${STAGED_FILES}" | xargs grep -l "^<<<<<<< \|^=======$\|^>>>>>>> " 2>/dev/null; then
        print_fail "Merge conflict markers found in staged files!"
        PASS=false
    else
        print_pass "No merge conflict markers"
    fi

    # Check for large files (>1MB)
    local large_files=()
    while IFS= read -r file; do
        if [ -f "${file}" ]; then
            local size
            size=$(stat -f%z "${file}" 2>/dev/null || stat -c%s "${file}" 2>/dev/null)
            if [ "${size:-0}" -gt 1048576 ]; then
                large_files+=("${file}")
            fi
        fi
    done <<< "${STAGED_FILES}"

    if [ ${#large_files[@]} -gt 0 ]; then
        print_fail "Large files detected (>1MB):"
        for lf in "${large_files[@]}"; do
            echo -e "  ${RED}   - ${lf}${NC}"
        done
        PASS=false
    else
        print_pass "No large files detected"
    fi

    # Check for forbidden files
    local forbidden_extensions="\.(class|jar|war|ear|zip|tar\.gz|7z|dll|exe|so|dylib|keystore|jks|p12|pfx)"
    local forbidden_files=()
    while IFS= read -r file; do
        if echo "${file}" | grep -qiE "${forbidden_extensions}"; then
            forbidden_files+=("${file}")
        fi
    done <<< "${STAGED_FILES}"

    if [ ${#forbidden_files[@]} -gt 0 ]; then
        print_fail "Binary/forbidden files staged:"
        for ff in "${forbidden_files[@]}"; do
            echo -e "  ${RED}   - ${ff}${NC}"
        done
        PASS=false
    else
        print_pass "No forbidden file types"
    fi
fi

# ============================================================================
# Check 3: Commit Message Linting
# ============================================================================
print_section "3/8 💬  Commit Message Validation"

COMMIT_MSG_FILE="${1:-}"

if [ -z "${COMMIT_MSG_FILE}" ]; then
    # Try to get commit message from .git/COMMIT_EDITMSG
    COMMIT_MSG_FILE=".git/COMMIT_EDITMSG"
fi

if [ -f "${COMMIT_MSG_FILE}" ]; then
    COMMIT_MSG=$(head -n 1 "${COMMIT_MSG_FILE}" 2>/dev/null || echo "")

    # Conventional commit pattern
    if echo "${COMMIT_MSG}" | grep -qE "^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9._-]+\))?: .+"; then
        print_pass "Commit message follows conventional commits format"
    elif echo "${COMMIT_MSG}" | grep -qE "^[A-Z]+-[0-9]+ .+"; then
        print_pass "Commit message follows JIRA ticket format"
    elif [ -z "${COMMIT_MSG}" ]; then
        print_fail "Commit message is empty!"
        PASS=false
    else
        print_info "Commit message: '${COMMIT_MSG}'"
        print_info "Tip: Use conventional commits format: type(scope): description"
        print_info "     e.g., feat(auth): add login endpoint"
    fi

    # Check message length
    local msg_length
    msg_length=${#COMMIT_MSG}
    if [ "${msg_length}" -gt 72 ]; then
        print_fail "Commit message exceeds 72 characters (${msg_length} chars)"
        PASS=false
    else
        print_pass "Commit message length is valid (${msg_length} chars)"
    fi
fi

# ============================================================================
# Check 4: Code Formatting (Spotless)
# ============================================================================
print_section "4/8 🎨  Code Formatting Check"

if command -v ./gradlew &> /dev/null; then
    run_gradle_task "spotlessCheck" "Spotless code formatting" "${REPORT_DIR}/spotless-${TIMESTAMP}.log"
fi

# ============================================================================
# Check 5: Static Code Analysis - Detekt (Kotlin)
# ============================================================================
print_section "5/8 🔍  Detekt Static Analysis (Kotlin)"

if command -v ./gradlew &> /dev/null; then
    run_gradle_task "detektMain" "Detekt Kotlin analysis" "${REPORT_DIR}/detekt-${TIMESTAMP}.log"
fi

# ============================================================================
# Check 6: Static Code Analysis - Checkstyle (Java)
# ============================================================================
print_section "6/8 📐  Checkstyle Analysis (Java)"

if command -v ./gradlew &> /dev/null; then
    run_gradle_task "checkstyleMain" "Checkstyle Java analysis" "${REPORT_DIR}/checkstyle-${TIMESTAMP}.log"
fi

# ============================================================================
# Check 7: Unit Tests & Coverage
# ============================================================================
print_section "7/8 🧪  Unit Tests & Coverage"

if command -v ./gradlew &> /dev/null; then
    # Run tests with coverage
    if run_gradle_task "test jacocoTestReport" "Unit tests and JaCoCo coverage" "${REPORT_DIR}/test-${TIMESTAMP}.log"; then
        # Extract coverage summary if available
        local coverage_reports
        coverage_reports=$(find . -path "*/build/reports/jacoco/*/html/index.html" 2>/dev/null | head -5)
        if [ -n "${coverage_reports}" ]; then
            print_info "Coverage reports available at:"
            for report in ${coverage_reports}; do
                echo -e "     ${CYAN}${report}${NC}"
            done
        fi
    fi
fi

# ============================================================================
# Check 8: Dependency Vulnerability Check
# ============================================================================
print_section "8/8 🔒  Dependency Vulnerability Check"

if command -v ./gradlew &> /dev/null; then
    run_gradle_task "dependencyCheckAnalyze" "OWASP Dependency Check" "${REPORT_DIR}/dependency-check-${TIMESTAMP}.log" || true
fi

# ============================================================================
# Summary
# ============================================================================
echo ""
echo -e "${CYAN}${BOLD}╔══════════════════════════════════════════════════════════════╗${NC}"
if [ "${PASS}" = true ]; then
    echo -e "${CYAN}${BOLD}║     ✅  ALL CHECKS PASSED - COMMIT ALLOWED                ║${NC}"
    echo -e "${CYAN}${BOLD}╚══════════════════════════════════════════════════════════════╝${NC}"
    echo ""
    echo -e "  ${GREEN}Commit is ready to proceed!${NC}"
    echo ""
else
    echo -e "${RED}${BOLD}║     ❌  SOME CHECKS FAILED - COMMIT BLOCKED               ║${NC}"
    echo -e "${RED}${BOLD}╚══════════════════════════════════════════════════════════════╝${NC}"
    echo ""
    echo -e "  ${RED}Please fix the issues above and try again.${NC}"
    echo ""
    echo -e "  ${YELLOW}To bypass checks temporarily (not recommended):${NC}"
    echo -e "    git commit --no-verify -m \"your message\""
    echo ""
    exit 1
fi