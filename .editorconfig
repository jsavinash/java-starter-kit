# EditorConfig - https://editorconfig.org
# This file ensures consistent coding styles across editors and IDEs

# Top-level settings
root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Markdown files
[*.md]
trim_trailing_whitespace = false

# YAML files
[*.{yml,yaml}]
indent_size = 2

# JSON files
[*.json]
indent_size = 2

# XML files
[*.xml]
indent_size = 2

# Properties files
[*.properties]
indent_size = 2

# Gradle Kotlin DSL
[*.gradle.kts]
indent_size = 4

# Kotlin files
[*.kt]
ktlint_code_style = intellij_idea
ktlint_function_signature_body_expression_wrapping = default
ktlint_ignore_back_ticked_identifier = true

# Java files
[*.java]
indent_size = 4

# Shell scripts
[*.sh]
indent_size = 2
end_of_line = lf

# Batch files
[*.bat]
end_of_line = crlf